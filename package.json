  "author": "tmslpm",
  "description": "private project",
  "scripts": {
    "start": "tsx --watch ./src/main/index.ts | pino-pretty",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "buf:setup": "npm run buf:dep && npm run buf:build",
    "buf:gen": "npx buf generate --template ./protobufs/buf.gen.yaml .",
    "buf:dep": "npx buf dep update",
    "buf:build": "npm buf:build",
    "docker:up": "docker compose up -d"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protovalidate": "^1.1.1",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "type": "module",
  "main": "index.js"
}
